@schema {id crate:tracey-config@1, cli tracey}

specs (
    {
        name binette
        include (docs/content/spec/*.md)
        impls (
            {
                name rust
                include (rust/**/*.rs)
            }
            {
                name typescript
                include (typescript/**/*.ts)
                exclude (
                    typescript/*/dist/**
                    typescript/*/dist-test/**
                )
            }
        )
    }
)
